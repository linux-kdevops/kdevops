# fstests
CONFIG_WORKFLOWS_DEDICATED_WORKFLOW=y
CONFIG_KDEVOPS_WORKFLOW_DEDICATE_FSTESTS=y
CONFIG_KDEVOPS_WORKFLOW_ENABLE_FSTESTS=y
CONFIG_FSTESTS_XFS=y
CONFIG_FSTESTS_FSTYP="xfs"

# Opt into manual section selection so the per-section symbols
# below are the ones the kdevops Kconfig exposes a prompt on.
# With MANUAL_COVERAGE=n, xfs/Kconfig auto-enables every section
# through a second "default y" declaration under
# `if !FSTESTS_XFS_MANUAL_COVERAGE`, and the `is not set` lines
# below never land in .config.
CONFIG_FSTESTS_XFS_MANUAL_COVERAGE=y

CONFIG_FSTESTS_XFS_SECTION_CRC=y
# CONFIG_FSTESTS_XFS_SECTION_NOCRC is not set
# CONFIG_FSTESTS_XFS_SECTION_NOCRC_512 is not set

# Reflink is not autoselected on most distros (the distro gate
# HAVE_DISTRO_XFS_SUPPORTS_REFLINKS defaults to n), so enable
# the reflink umbrella explicitly; then opt into only the base
# reflink section and leave the 1024/NORMAPBT variants off.
CONFIG_FSTESTS_XFS_SECTION_REFLINK_ENABLED=y
CONFIG_FSTESTS_XFS_SECTION_REFLINK=y
# CONFIG_FSTESTS_XFS_SECTION_REFLINK_1024 is not set
# CONFIG_FSTESTS_XFS_SECTION_REFLINK_NORMAPBT is not set

# External log device (xfs_*_logdev sections) is also gated on a
# distro autoselect (HAVE_DISTRO_XFS_SUPPORTS_EXTERNAL_LOG) that
# defaults n on NixOS, so enable the umbrella explicitly. The
# qsu config-qsu task wires TEST_LOGDEV and SCRATCH_LOGDEV from
# the per-VM NVMe drives when the disk count is >= 5
# (CONFIG_QEMU_SYSTEM_UNITS_EXTRA_STORAGE_DRIVE_COUNT=9 above is
# well above that), so the device foundation is ready. CRC_LOGDEV
# and REFLINK_LOGDEV opt in to a dedicated VM each
# (qsu-xfs-crc-logdev, qsu-xfs-reflink-logdev) — bringing the qsu
# matrix to four VMs total. CRC_LOGDEV_RTDEV is left off because
# realtime devices need a separate RTDEV_ENABLED umbrella and
# config-qsu wiring not yet in place.
CONFIG_FSTESTS_XFS_SECTION_LOGDEV_ENABLED=y
CONFIG_FSTESTS_XFS_SECTION_CRC_LOGDEV=y
# CONFIG_FSTESTS_XFS_SECTION_CRC_LOGDEV_RTDEV is not set
CONFIG_FSTESTS_XFS_SECTION_REFLINK_LOGDEV=y

# Cap the external-log device size at 64 MiB (override of the
# kdevops default `-lsize=1g`).
#
# The default of 1 GiB is right for the steady-state journaling
# behaviour the LOGDEV section is meant to exercise, but a
# subset of xfstests (xfs/005, 263, 299, 304, 305 and similar
# that bring up scsi_debug as an alternate SCRATCH device)
# inherit the section's MKFS_OPTIONS verbatim through the
# environment when calling _scratch_mkfs against the alternate
# device. scsi_debug instances default to <= 600 MiB, and
# XFS's log-must-be-<=1/8-of-data rule then caps the maximum
# log at ~75 MiB. The inherited `-lsize=1g` blows past that
# limit and mkfs fails with
#     log size 5242880 blocks too large, maximum size is ...
# leaving the affected tests notrun under
#     _scratch_mkfs_xfs failed with (-m crc=1)
#
# 64 MiB still exercises external-log behaviour (still
# noticeably larger than the default mkfs.xfs log auto-sizing
# would pick for a 50 GiB drive, ~38-50 MiB) and stays well
# inside the 1/8 cap of every scsi_debug size used by the
# affected tests. Recovers ~5 tests per logdev VM.
#
# Keep this override scoped to the qsu defconfig rather than
# changing the global FSTESTS_TEST_LOGDEV_MKFS_OPTS default —
# the libvirt path is unaffected (no scsi_debug-as-alt-scratch
# clash there) and a different consumer might prefer the bigger
# log. The xfstests upstream long-form fix is for tests to
# unset MKFS_OPTIONS when overriding SCRATCH_DEV with
# scsi_debug; this works around the issue locally until that
# lands.
CONFIG_FSTESTS_TEST_LOGDEV_MKFS_OPTS="-lsize=64m"

# Pipe oscheck.sh output through systemd-cat on the guest so
# a `journalctl --identifier=fstests --follow` tail on the
# controller (or the guest itself) can watch the per-section
# run live without scraping the ansible callback output.
CONFIG_FSTESTS_ENABLE_JOURNAL=y

CONFIG_QEMU_SYSTEM_UNITS_EXTRA_STORAGE_DRIVE_COUNT=9

# Provision every extra NVMe drive as 4Kn (native 4 KiB everywhere)
# with aligned I/O hints and a 4 KiB discard granularity. This
# matches what modern enterprise SSDs advertise and ensures
# xfstests exercises the 4 KiB-block path consistently across all
# four VMs (qsu-xfs-crc, qsu-xfs-reflink, and the two _LOGDEV
# variants). Each knob accepts a single value (applied to every
# drive) or a comma-separated list of length 9 if heterogeneous
# shapes are needed; here we go uniform 4 KiB so the matrix tests
# one shape coherently.
#
#   logical_block_size:  LBA size, surfaces as NVMe LBADS in the
#                        Identify Namespace formatted_lba_size.
#   physical_block_size: must be >= LBS; 4096/4096 is "4Kn".
#   min_io_size:         NPWG, the NVMe Preferred Write Granularity
#                        the guest filesystem aligns to.
#   opt_io_size:         NPWA, the NVMe Preferred Write Alignment
#                        the kernel block layer picks for stripes.
#   discard_granularity: minimum DSM deallocate unit; 4 KiB matches
#                        one logical block so trim alignment is
#                        unambiguous on the guest side.
CONFIG_QEMU_SYSTEM_UNITS_EXTRA_STORAGE_LOGICAL_BLOCK_SIZE="4096"
CONFIG_QEMU_SYSTEM_UNITS_EXTRA_STORAGE_PHYSICAL_BLOCK_SIZE="4096"
CONFIG_QEMU_SYSTEM_UNITS_EXTRA_STORAGE_MIN_IO_SIZE="4096"
CONFIG_QEMU_SYSTEM_UNITS_EXTRA_STORAGE_OPT_IO_SIZE="4096"
CONFIG_QEMU_SYSTEM_UNITS_EXTRA_STORAGE_DISCARD_GRANULARITY="4096"

# Point kdevops at a kernel tree the user maintains themselves
# (a git worktree, a manual clone, or a symlink). Whatever HEAD is
# in that tree gets built; kdevops detects the existing checkout
# in playbooks/roles/bootlinux/tasks/build/controller.yml and
# skips clone / fetch / checkout entirely. Iteration loop becomes:
#
#     git checkout / git rebase / edit / git commit  (in the tree)
#     make linux-install
#     make linux-deploy
#
# With CONFIG_LOCALVERSION_AUTO=y in the kdevops config-qsu kernel
# fragment (see playbooks/roles/bootlinux/templates/config-qsu),
# every distinct source revision lands at a distinct
# uname -r and a distinct workflows/fstests/results/<vm>/<kernel>/
# directory, so A/B comparisons stay untangled.
CONFIG_BOOTLINUX_CONTROLLER_TREE_PATH="/home/dagomez/src/kernel/wt/linux"

# xfstests source tree the user maintains themselves. Same model
# as the kernel tree: kdevops uses whatever HEAD is here without
# touching git state.
CONFIG_FSTESTS_GIT="/home/dagomez/src/xfstests-dev"
CONFIG_FSTESTS_GIT_VERSION="HEAD"

CONFIG_WORKFLOW_XFSPROGS_GIT="/home/dagomez/src/xfsprogs-dev"
CONFIG_WORKFLOW_XFSPROGS_GIT_VERSION="HEAD"

# Monitoring framework — turns the report's per-host monitoring
# section into a usable triage view by capturing the host context
# every fstests run actually depends on (kernel cmdline + taint,
# CPU mitigations, microcode, clocksource, THP/VM tuning, LSM
# state, DMI identity, BIOS revision, hostname/distro/CPU model).
#
# CONFIG_MONITOR_SNAPSHOTS_ALL is the convenience knob — flipping
# it default-y's every snapshot-style monitor (cpu_governor,
# blockdev, host_info, boot_params, cpu_features, clocksource,
# vm_tuning, lsm, dmi). Individual monitors can still be disabled
# explicitly when this is set.
#
# system_metrics is the only time-series monitor here; it is opted
# in separately because its overhead and output-volume profile is
# different from the start/end snapshot pattern. The 1s interval
# matches the resolution the test-execution timeline overlay in
# the fstests report aligns against.
CONFIG_ENABLE_MONITORING=y
CONFIG_MONITOR_SYSTEM_METRICS=y
CONFIG_MONITOR_SYSTEM_METRICS_INTERVAL=1
CONFIG_MONITOR_SNAPSHOTS_ALL=y
