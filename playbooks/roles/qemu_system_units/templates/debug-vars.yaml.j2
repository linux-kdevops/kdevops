# SPDX-License-Identifier: copyleft-next-0.3.1
#
# qemu-system-units vars snapshot for {{ vm_name }}. Generated by
# kdevops at bringup time (scripts/qemu-system-units/vars/ is
# gitignored). Debug artefact: nothing in kdevops reads this file.

vm_name: {{ vm_name }}
service_scope: {{ service_scope | default('user') }}

# QEMU
qemu_binary: {{ qemu_binary }}
cpu: {{ cpu }}
accel: {{ accel }}
ram: {{ ram }}
cpus: {{ cpus }}
machine_type: {{ machine_type }}

# Networking
ssh_port: {{ ssh_port }}
vsock_cid: {{ vsock_cid }}

# Direct kernel boot
kernel:
  image: {{ kernel.image }}
  initrd: {{ kernel.initrd }}
  append: {{ kernel.append }}

# virtiofs shares (host dir -> guest mount)
shares:
{% for s in shares %}
  - tag: {{ s.tag }}
    dir: {{ s.dir }}
    mount: {{ s.mount }}
{% endfor %}

{% if nvme is defined and nvme.drives | default([]) | length > 0 %}
# NVMe drives (one controller per drive, implicit namespace)
nvme:
  drives:
{% for d in nvme.drives %}
    - file: {{ d.file }}
      format: {{ d.format | default('qcow2') }}
      serial: {{ d.serial }}
{% endfor %}
{% endif %}
